          "editorMode": "code",
          "expr": "topk(10, sum by (provider, model, outcome) (increase({__name__=~\"chat_turn_errors(_total)?\"}[$__range])))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{provider}} {{model}} {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Top Error Buckets",
