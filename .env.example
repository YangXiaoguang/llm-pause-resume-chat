#     "description":"Claude with prompt caching",
#     "defaultModel":"claude-sonnet-4-20250514",
#     "supportsPromptCaching":true,
#     "baseUrl":"https://api.anthropic.com",
#     "apiKeyEnv":"ANTHROPIC_API_KEY"
#   },
#   {
