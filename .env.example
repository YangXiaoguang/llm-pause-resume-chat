CHAT_SESSION_REPOSITORY=file

OBS_ENABLED=true
OBS_LOG_LEVEL=info
OBS_CAPTURE_CONTENT_MODE=off
OTEL_SERVICE_NAME=llm-pause-resume-chat
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_METRIC_EXPORT_INTERVAL=10000

# The local observability stack now fronts Grafana LGTM with an OpenTelemetry
# Collector so redaction and tail sampling happen before telemetry is stored.
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_RELEASE=local
LANGFUSE_EXPORT_MODE=immediate
LANGFUSE_SCORE_ENABLED=true
LANGFUSE_PROMPT_LABEL=production
LANGFUSE_PROMPT_CACHE_TTL_SECONDS=300

# Built-in Anthropic adapter
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Built-in OpenAI-compatible adapter
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4.1-mini
#OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-4c661f46c70e42ea9fcf6c229682d398
OPENAI_MODEL=qwen-max
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional Langfuse integration for iteration 2: trace export, prompt
# versioning, and session/turn correlation in the Langfuse UI.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://127.0.0.1:3003

# Optional: define providers declaratively instead of using the built-ins.
# Example:
# LLM_PROVIDER_REGISTRY_JSON=[
#   {
#     "id":"anthropic-prod",
#     "kind":"anthropic",
#     "label":"Anthropic Claude",
#     "description":"Claude with prompt caching",
#     "defaultModel":"claude-sonnet-4-20250514",
#     "supportsPromptCaching":true,
#     "baseUrl":"https://api.anthropic.com",
#     "apiKeyEnv":"ANTHROPIC_API_KEY"
#   },
#   {
#     "id":"gateway",
#     "kind":"openai-compatible",
#     "label":"Gateway",
#     "description":"Internal OpenAI-compatible gateway",
#     "defaultModel":"my-model",
#     "baseUrl":"https://gateway.example.com/v1",
#     "apiKeyEnv":"OPENAI_API_KEY"
#   }
# ]
